{
  "name": "@magnusrodseth/shadcn-mcp-server",
  "version": "1.1.2",
  "description": "MCP Server for shadcn/ui components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magnusrodseth/shadcn-mcp-server.git"
  },
  "homepage": "https://github.com/magnusrodseth/shadcn-mcp-server",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "shadcn-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "dev": "tsx watch index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "test:mcp": "node scripts/test-mcp.js",
    "test:manual": "pnpm run build && node dist/index.js",
    "test:cursor": "node scripts/test-cursor.js",
    "version:bump": "tsx scripts/version-bump.ts",
    "version:patch": "tsx scripts/version-bump.ts --type patch",
    "version:minor": "tsx scripts/version-bump.ts --type minor",
    "version:major": "tsx scripts/version-bump.ts --type major",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "package:publish": "pnpm run version:bump && pnpm publish --access public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "shadcn",
    "shadcn-ui",
    "components",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.16.0",
    "axios": "^1.10.0",
    "cheerio": "^1.1.2",
    "commander": "^14.0.0",
    "dotenv": "^17.2.0",
    "winston": "^3.17.0",
    "zod": "^4.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
